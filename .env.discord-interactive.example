# Discord Interactive Bot — single Discord bot with switchable CLI routing
# Copy to .env.discord-interactive and fill in real values.

# Required: Discord bot credentials from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

# Optional: restrict slash command registration to one guild for instant propagation.
# Leave blank for global commands (~1 hour propagation).
DISCORD_GUILD_ID=

# Comma-separated Discord snowflake user IDs allowed to send commands.
DISCORD_ALLOWED_USER_IDS=

# CLI commands (defaults shown)
CODEX_COMMAND=codex
CLAUDE_COMMAND=claude
ANTIGRAVITY_COMMAND=agy

# Standard effort defaults. Agy stores/displays this only; no CLI effort flag exists.
CODEX_EFFORT=medium
CLAUDE_EFFORT=medium
ANTIGRAVITY_EFFORT=medium

# Fallback sequence/preference order for the CLI chain
INTERACTIVE_CLI_CHAIN=codex,claude,antigravity

# Default CLI for new channels (codex | claude | antigravity)
INTERACTIVE_DEFAULT_CLI=codex

# SQLite path for session and preferences state
# DB_PATH=

# "safe" or "trusted" mode. Discord interactive matches Telegram bots by default.
BRIDGE_EXECUTION_MODE=trusted

# Set to "false" to use synchronous (blocking) CLI execution
BRIDGE_ASYNC_ENABLED=true

# Busy-message admission: interrupt the active turn (default) or opt into FIFO queueing.
BRIDGE_BUSY_MESSAGE_MODE=interrupt

# Optional CLI hard/idle timeouts in milliseconds; 0 disables each timeout.
# CLI_TIMEOUT_MS=0
# CLI_IDLE_TIMEOUT_MS=0

# Agent Bridge SOUL.md context (optional)
# AGENT_BRIDGE_SOUL_PATH=
# AGENT_BRIDGE_SOUL_MODE=
