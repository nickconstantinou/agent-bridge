# Worker bot — autonomous job queue control surface
# Copy to .env.worker and fill in real values.

TELEGRAM_BOT_TOKEN_WORKER=<token-from-botfather>
TELEGRAM_ALLOWED_USER_IDS=<your-telegram-user-id>

# Phase 0: keep false until Phase 1 schema (work_items/work_jobs) is deployed
WORKER_ENABLED=false

# Shared DB path — must match other bridge services
# DB_PATH=/home/BRIDGE_USER/.data/bridge.sqlite

# CLI fallback chain for job execution (comma-separated, tried in order)
WORKER_CLI_CHAIN=codex,claude,antigravity

# Default repository for scans when none specified in /review
WORKER_DEFAULT_REPO=agent-bridge

# Phase flags — default all off until the corresponding phase is verified
WORK_QUEUE_ENABLED=false
DEFECT_SCAN_ENABLED=false
FEATURE_PLANNING_ENABLED=false
GITHUB_ISSUE_WRITE_ENABLED=false
GITHUB_PR_WRITE_ENABLED=false
GITHUB_MERGE_APPROVAL_ENABLED=false
