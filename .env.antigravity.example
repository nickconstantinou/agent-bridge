TELEGRAM_BOT_TOKEN_ANTIGRAVITY=123456:replace-me
TELEGRAM_ALLOWED_USER_IDS=123456789

BRIDGE_ROOT_DIR=/home/your-user
BRIDGE_PROJECT_DIR=/home/your-user/agent-bridge

ANTIGRAVITY_COMMAND=agy
ANTIGRAVITY_MODEL_PREFERENCE=gemini-3.5-flash-high,gemini-3.5-flash-medium,gemini-3.1-pro-high,gemini-3.1-pro-low,claude-4.6-sonnet-thinking,claude-4.6-opus-thinking
ANTIGRAVITY_PROJECT_DIR=
BRIDGE_EXECUTION_MODE=trusted
BRIDGE_ASYNC_ENABLED=true
CLI_TIMEOUT_MS=300000
CLI_IDLE_TIMEOUT_MS=60000
FETCH_TIMEOUT_MS=45000
POLL_INTERVAL_MS=1000
AGENT_MEMORY_DB_PATH=
AGENT_BRIDGE_SOUL_PATH=
AGENT_BRIDGE_SOUL_MODE=summary
DB_PATH=.data-antigravity/bridge.sqlite
