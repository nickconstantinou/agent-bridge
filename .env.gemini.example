TELEGRAM_BOT_TOKEN_GEMINI=123456:replace-me
TELEGRAM_ALLOWED_USER_ID=123456789

BRIDGE_ROOT_DIR=/home/your-user
BRIDGE_PROJECT_DIR=/home/your-user/.openclaw/workspace/projects/agent-bridge

GEMINI_COMMAND=gemini
GEMINI_MODEL_PREFERENCE=gemini-3.1-pro-preview,gemini-3.1-flash-lite-preview,gemini-2.5-pro,gemini-2.5-flash-lite
BRIDGE_EXECUTION_MODE=trusted
BRIDGE_ASYNC_ENABLED=true
POLL_INTERVAL_MS=1000
CLI_TIMEOUT_MS=300000
DB_PATH=.data-gemini/bridge.sqlite
