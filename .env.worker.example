# Worker bot — autonomous job queue control surface
# Copy to .env.worker and fill in real values.

TELEGRAM_BOT_TOKEN_WORKER=<token-from-botfather>
TELEGRAM_ALLOWED_USER_IDS=<your-telegram-user-id>

# GitHub owner for worker repo picker and bare repo names.
GITHUB_USERNAME=<your-github-username>

# Operator safety switch. Keep false until the worker token, GitHub token, repo
# root, and feature flags are intentionally configured for this host.
WORKER_ENABLED=false

# Worker DB path. Keep separate from interactive bot DBs unless you are
# deliberately sharing worker state.
# DB_PATH=/home/BRIDGE_USER/.data/worker.sqlite

# CLI fallback chain for job execution (comma-separated, tried in order)
WORKER_CLI_CHAIN=codex,claude,antigravity

# Shared effort defaults. Worker jobs choose task-specific effort:
# scribe/read-only = medium, code-writing = high. Agy effort is a no-op because
# the Agy CLI has no standalone effort flag.
CODEX_EFFORT=medium
CLAUDE_EFFORT=medium
ANTIGRAVITY_EFFORT=medium

# Default repository for scans when none specified in /review, /refactor, or /feature
WORKER_DEFAULT_REPO=agent-bridge

# Feature flags — default all off until the corresponding capability is
# intentionally enabled for this deployment.
WORK_QUEUE_ENABLED=false
DEFECT_SCAN_ENABLED=false
FEATURE_PLANNING_ENABLED=false
GITHUB_ISSUE_WRITE_ENABLED=false
GITHUB_PR_WRITE_ENABLED=false
GITHUB_MERGE_APPROVAL_ENABLED=false

# PR lifecycle controls
WORKER_MAX_OPEN_PRS=3
WORKER_MAX_DAILY_PRS=3
WORKER_PR_STALE_HOURS=72
WORKER_PR_WATCH_INTERVAL=3600000
