# Interactive bot — single Telegram bot with switchable CLI routing
# Copy to .env.interactive and fill in real values.

TELEGRAM_BOT_TOKEN_INTERACTIVE=<token-from-botfather>
TELEGRAM_ALLOWED_USER_IDS=<your-telegram-user-id>

# CLI commands (defaults shown)
CODEX_COMMAND=codex
CLAUDE_COMMAND=claude
ANTIGRAVITY_COMMAND=agy
KIMCHI_COMMAND=~/.local/bin/kimchi
KIMCHI_MODEL_PREFERENCE=kimi-k2.7,nemotron-3-ultra-fp4,minimax-m3,deepseek-v4-flash

# Kimchi API key (required for kimchi CLI)
KIMCHI_API_KEY=<kimchi-api-key>

# Standard effort defaults. Agy stores/displays this only; no CLI effort flag exists.
CODEX_EFFORT=medium
CLAUDE_EFFORT=medium
ANTIGRAVITY_EFFORT=medium
KIMCHI_EFFORT=medium

# Execution mode: safe (classifier/approval prompts) or trusted (bypass).
# Kimchi defaults to trusted; set KIMCHI_EXECUTION_MODE=safe to keep classifier guards.
KIMCHI_EXECUTION_MODE=trusted

# Default CLI for new users (codex | claude | antigravity | kimchi)
# Per-user preference is stored in SQLite and overrides this default.
INTERACTIVE_DEFAULT_CLI=codex

# CLI-to-CLI fallback order after the active CLI's model fallbacks are exhausted.
INTERACTIVE_CLI_CHAIN=codex,claude,antigravity,kimchi

# Ordinary messages interrupt the active turn by default. Set queue to retain
# durable FIFO behavior instead.
BRIDGE_BUSY_MESSAGE_MODE=interrupt

# Hard and idle CLI timeouts are disabled by default. Set positive values when
# an operational timeout is explicitly required.
# CLI_TIMEOUT_MS=0
# CLI_IDLE_TIMEOUT_MS=0

# Interactive DB path. Keep separate from dedicated bot DBs unless you are
# deliberately sharing sessions and model state.
# DB_PATH=/home/BRIDGE_USER/.data/interactive.sqlite

# Soul/persona context (optional)
# AGENT_BRIDGE_SOUL_PATH=/path/to/SOUL.md
