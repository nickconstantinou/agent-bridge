TELEGRAM_BOT_TOKEN_ANTIGRAVITY=123456:replace-me
TELEGRAM_ALLOWED_USER_IDS=123456789

BRIDGE_ROOT_DIR=/home/your-user
BRIDGE_PROJECT_DIR=/home/your-user/.openclaw/workspace/projects/agent-bridge

ANTIGRAVITY_COMMAND=antigravity
ANTIGRAVITY_MODEL_PREFERENCE=antigravity-3.1-pro-preview,antigravity-3.1-flash-lite-preview,antigravity-2.5-pro,antigravity-2.5-flash-lite
BRIDGE_EXECUTION_MODE=trusted
BRIDGE_ASYNC_ENABLED=true
CLI_TIMEOUT_MS=300000
CLI_IDLE_TIMEOUT_MS=60000
FETCH_TIMEOUT_MS=45000
DB_PATH=.data-antigravity/bridge.sqlite
