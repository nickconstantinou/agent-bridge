# Shared configuration — loaded by all agent-bridge services before bot-specific env files.
# Bot-specific values (token, command, DB path, model prefs) stay in .env.{bot}.
# Values here are overridden by the bot-specific file if the same key appears in both.

BRIDGE_ROOT_DIR=
BRIDGE_PROJECT_DIR=
NODE_BIN=

TELEGRAM_ALLOWED_USER_IDS=123456789

BRIDGE_EXECUTION_MODE=safe
# Per-bot overrides: KIMCHI_EXECUTION_MODE, CODEX_EXECUTION_MODE, etc.
# Kimchi defaults to trusted if neither is set.
BRIDGE_ASYNC_ENABLED=true
POLL_INTERVAL_MS=1000
FETCH_TIMEOUT_MS=45000

AGENT_MEMORY_DB_PATH=
AGENT_BRIDGE_SOUL_PATH=
AGENT_BRIDGE_SOUL_MODE=summary

# Health monitoring (normally enabled only in agent-bridge-health.service)
HEALTH_MONITOR_ENABLED=false
HEALTH_MONITOR_CADENCE_SECONDS=3600
HEALTH_MONITOR_AUTONOMY=report
HEALTH_MONITOR_CHAT_ID=
HEALTH_SUGGEST_BOT=claude
HEALTH_CONTENT_CRAWLER_ENABLED=0
HEALTH_CONTENT_CRAWLER_SCRIPT=

# Server monitor configuration (CPU load thresholds as multipliers of CPU count)
# HEALTH_CPU_LOAD_AMBER_MULTIPLIER=1.0
# HEALTH_CPU_LOAD_RED_MULTIPLIER=1.5
# Or set absolute thresholds:
# HEALTH_CPU_LOAD_AMBER_THRESHOLD=4.0
# HEALTH_CPU_LOAD_RED_THRESHOLD=6.0
