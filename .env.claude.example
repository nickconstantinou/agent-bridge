TELEGRAM_BOT_TOKEN_CLAUDE=your-token

CLAUDE_COMMAND=claude
CLAUDE_MODEL_PREFERENCE=claude-sonnet-5,claude-opus-4-8,claude-haiku-4-5,claude-fable-5
CLAUDE_EFFORT=medium
CLAUDE_PROJECT_DIR=
# Per-bot timeout overrides (defaults: 1800s hard, 1200s idle)
# CLAUDE_CLI_TIMEOUT_MS=1800000
# CLAUDE_CLI_IDLE_TIMEOUT_MS=1200000
DB_PATH=.data-claude/bridge.sqlite
