ANTIGRAVITY_COMMAND=agy
ANTIGRAVITY_MODEL_PREFERENCE=gemini-3.5-flash-high,gemini-3.5-flash-medium,gemini-3.1-pro-high,gemini-3.1-pro-low,claude-4.6-sonnet-thinking,claude-4.6-opus-thinking
