# Install as /etc/agent-bridge/rollout.conf with root:root ownership and mode 0600.
# This is a fixed allowlist, not a shell file. Values cannot contain newlines.
# Immutable release mode: project_dir is not required when these two values
# are present. The current pointer must resolve to the expected staged SHA.
release_root=/opt/agent-bridge/releases
current_pointer=/opt/agent-bridge/releases/current
# Replace this placeholder with the SHA-256 of the installed helper before use.
rollout_helper_sha256=REPLACE_WITH_SHA256_OF_INSTALLED_HELPER
runtime_user=content-crawler
node_bin=/home/content-crawler/.nvm/versions/node/v24.15.0/bin/node
backup_dir=/var/backups/agent-bridge
log_dir=/var/log/agent-bridge-rollouts
unit=agent-bridge-antigravity.service
unit=agent-bridge-claude.service
unit=agent-bridge-codex.service
unit=agent-bridge-discord-interactive.service
unit=agent-bridge-health.service
unit=agent-bridge-interactive.service
unit=agent-bridge-worker-bot.service
database=/home/content-crawler/agent-bridge/.data/bridge.sqlite
database=/home/content-crawler/agent-bridge/.data/discord-interactive.sqlite
database=/home/content-crawler/agent-bridge/.data-health/health.sqlite
database=/home/content-crawler/runtime/agent-bridge/interactive/bridge.sqlite
database=/home/content-crawler/runtime/agent-bridge/worker/bridge.sqlite
