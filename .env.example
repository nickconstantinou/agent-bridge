TELEGRAM_BOT_TOKEN_CODEX=123456:replace-me
TELEGRAM_BOT_TOKEN_GEMINI=123456:replace-me
TELEGRAM_BOT_TOKEN_CLAUDE=123456:replace-me

# Single user:
TELEGRAM_ALLOWED_USER_IDS=123456789
# Multiple users (comma-separated):
# TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# Project paths
BRIDGE_ROOT_DIR=/path/to/your/home
BRIDGE_PROJECT_DIR=/path/to/your/agent-bridge-repo
BRIDGE_ENV_FILE=/absolute/path/to/this/repo/.env
CODEX_PROJECT_DIR=/absolute/path/to/codex-repo
GEMINI_PROJECT_DIR=/absolute/path/to/gemini-repo
CLAUDE_PROJECT_DIR=/absolute/path/to/claude-repo

# Command overrides
CODEX_COMMAND=codex
GEMINI_COMMAND=gemini
CLAUDE_COMMAND=claude

# Model preferences
CLAUDE_MODEL_PREFERENCE=claude-opus-4-7,claude-sonnet-4-6

# Execution settings
BRIDGE_EXECUTION_MODE=trusted
BRIDGE_ASYNC_ENABLED=true

# Timeouts — all optional. Precedence: per-CLI > global > built-in default.
# Built-in defaults: hard 600s (all), idle: codex 90s / gemini 240s / claude 180s
#
# Global fallbacks (apply to all CLIs unless overridden below):
# CLI_TIMEOUT_MS=600000
# CLI_IDLE_TIMEOUT_MS=90000
#
# Per-CLI overrides:
# CODEX_CLI_TIMEOUT_MS=600000
# CODEX_CLI_IDLE_TIMEOUT_MS=90000
# GEMINI_CLI_TIMEOUT_MS=600000
# GEMINI_CLI_IDLE_TIMEOUT_MS=240000
# CLAUDE_CLI_TIMEOUT_MS=600000
# CLAUDE_CLI_IDLE_TIMEOUT_MS=180000
#
# Telegram API fetch timeout only (never kills a CLI subprocess):
# TELEGRAM_FETCH_TIMEOUT_MS=45000

# Persistence
DB_PATH=
