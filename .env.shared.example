# Shared configuration — loaded by all agent-bridge services before bot-specific env files.
# Bot-specific values (token, command, DB path, model prefs) stay in .env.{bot}.
# Values here are overridden by the bot-specific file if the same key appears in both.

BRIDGE_ROOT_DIR=
BRIDGE_PROJECT_DIR=
BRIDGE_CURRENT_RELEASE_DIR=
NODE_BIN=

TELEGRAM_ALLOWED_USER_IDS=123456789

BRIDGE_EXECUTION_MODE=safe
# Per-bot overrides: KIMCHI_EXECUTION_MODE, CODEX_EXECUTION_MODE, etc.
# Kimchi defaults to trusted if neither is set.
BRIDGE_ASYNC_ENABLED=true
# Busy-message admission: interrupt the active turn (default) or opt into FIFO queueing.
BRIDGE_BUSY_MESSAGE_MODE=interrupt
POLL_INTERVAL_MS=1000
FETCH_TIMEOUT_MS=45000

# Optional provider[:model] fallback order for compaction recovery.
# The healthy caller-selected provider is preferred; exhausted providers and Kimchi are excluded.
# Invalid and duplicate targets are ignored.
# BRIDGE_COMPACTION_CHAIN=claude:claude-sonnet-5,codex:gpt-5.6-sol,antigravity
BRIDGE_COMPACTION_MAX_ATTEMPTS=3
BRIDGE_COMPACTION_REPAIR_ATTEMPTS=1

# Optional frontier advisor. Routine work stays on the active executor; complex,
# risky, or stuck work may consult up to two ordered provider:model targets.
BRIDGE_ADVISOR_ENABLED=true
BRIDGE_ADVISOR_MODE=manual
# Advisor targets must support tool-free execution (currently claude or codex).
# We use Claude Fable as primary with Codex GPT-5.6 Sol as fallback.
BRIDGE_ADVISOR_CHAIN=claude:claude-fable-5,codex:gpt-5.6-sol
BRIDGE_ADVISOR_MAX_CALLS_PER_TURN=1
BRIDGE_ADVISOR_MAX_CALLS_PER_TASK=2
BRIDGE_ADVISOR_TIMEOUT_MS=120000
BRIDGE_ADVISOR_CONTEXT_MAX_CHARS=24000

AGENT_MEMORY_DB_PATH=
AGENT_BRIDGE_SOUL_PATH=
AGENT_BRIDGE_SOUL_MODE=summary

# Health monitoring (normally enabled only in agent-bridge-health.service)
HEALTH_MONITOR_ENABLED=false
HEALTH_MONITOR_CADENCE_SECONDS=3600
HEALTH_MONITOR_AUTONOMY=report
HEALTH_MONITOR_CHAT_ID=
HEALTH_SUGGEST_BOT=claude
HEALTH_CONTENT_CRAWLER_ENABLED=0
HEALTH_CONTENT_CRAWLER_SCRIPT=

# Server monitor configuration (CPU load thresholds as multipliers of CPU count)
# HEALTH_CPU_LOAD_AMBER_MULTIPLIER=1.0
# HEALTH_CPU_LOAD_RED_MULTIPLIER=1.5
# Or set absolute thresholds:
# HEALTH_CPU_LOAD_AMBER_THRESHOLD=4.0
# HEALTH_CPU_LOAD_RED_THRESHOLD=6.0
