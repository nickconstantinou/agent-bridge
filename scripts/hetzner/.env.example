# Hetzner Cloud API Configuration
HETZNER_API_TOKEN=your_hetzner_api_token_here

# SSH Key Configurations
# Path to the public key to upload to Hetzner
HETZNER_SSH_KEY_PATH=~/.ssh/id_rsa.pub
# Path to the private key used to connect to the VM
HETZNER_SSH_PRIVATE_KEY_PATH=~/.ssh/id_rsa

# Hetzner VPS Configuration
# Cheapest x86 instance type (2 vCPU, 4GB RAM)
HETZNER_SERVER_TYPE=cx22
# Default region: nbg1 (Nuremberg, Germany)
HETZNER_REGION=nbg1

# Optional: install and join Tailscale during cloud-init.
# Create an auth key in the Tailscale admin console. Ephemeral keys are safest for throwaway nodes.
TAILSCALE_AUTH_KEY=

# Local secrets environment file to deploy to VM
DEPLOY_ENV_FILE=.env.worker
