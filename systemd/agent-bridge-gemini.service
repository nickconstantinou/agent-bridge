[Unit]
Description=Telegram bridge for Gemini
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=BRIDGE_USER
EnvironmentFile=BRIDGE_HOME/agent-bridge/.env.gemini
Environment=BRIDGE_ENV_FILE=BRIDGE_HOME/agent-bridge/.env.gemini
ExecStart=/usr/bin/env bash -lc 'cd "${BRIDGE_PROJECT_DIR:?}" && exec ./node_modules/.bin/tsx src/index.ts'
Restart=always
RestartSec=5
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
