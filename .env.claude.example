# Health monitoring
HEALTH_MONITOR_ENABLED=true
HEALTH_MONITOR_CADENCE_SECONDS=3600
HEALTH_MONITOR_AUTONOMY=suggest
HEALTH_MONITOR_CHAT_ID=
