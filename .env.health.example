# Health monitoring bot — separate Telegram bot account, isolated from CLI bridge bots

TELEGRAM_BOT_TOKEN_HEALTH=your-health-bot-token

# CLI bot used for suggestions and follow-up conversations
HEALTH_CLI_BOT=claude
HEALTH_CLI_COMMAND=claude
HEALTH_CLI_MODEL_PREFERENCE=claude-sonnet-4-6,claude-opus-4-7

# Telegram chat to send reports to (must be accessible by the health bot)
HEALTH_MONITOR_CHAT_ID=

# Monitoring behaviour
HEALTH_MONITOR_ENABLED=true
HEALTH_MONITOR_CADENCE_SECONDS=3600
HEALTH_MONITOR_AUTONOMY=suggest

# Session TTL for follow-up conversations after a health report (seconds)
HEALTH_SESSION_TTL_SECONDS=1800

# Storage (separate from bridge bot DBs)
HEALTH_DB_PATH=.data-health/health.sqlite

# Optional external plugins
HEALTH_CONTENT_CRAWLER_ENABLED=0
HEALTH_CONTENT_CRAWLER_SCRIPT=
